t-page-breaks="true"><text:sequence-decls><text:sequence-decl text:display-outline-level="0" text:name="Illustration"/><text:sequence-decl text:display-outline-level="0" text:name="Table"/><text:sequence-decl text:display-outline-level="0" text:name="Text"/><text:sequence-decl text:display-outline-level="0" text:name="Drawing"/><text:sequence-decl text:display-outline-level="0" text:name="Figure"/></text:sequence-decls><text:p text:style-name="P1">A továbbtanuláshoz, illetve a munka világában szükséges szövegtípusok</text:p><text:p text:style-name="P2"/><text:h text:style-name="P3" text:outline-level="3">1. <text:span text:style-name="T1">Bevezetés</text:span></text:h><text:list text:style-name="L1"><text:list-item><text:p text:style-name="P4">A munka világában a hatékony kommunikáció alapfeltétel </text:p></text:list-item><text:list-item><text:p text:style-name="P4">A különböző helyzetekhez eltérő szövegtípusok tartoznak </text:p></text:list-item><text:list-item><text:p text:style-name="P5"><text:span text:style-name="T2">Ezek többsége </text:span><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">hivatalos, formális stílusú</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item></text:list><text:h text:style-name="P6" text:outline-level="3">2. <text:span text:style-name="T1">A munka világának főbb szövegtípusai</text:span></text:h><text:h text:style-name="P7" text:outline-level="4">2.1. <text:span text:style-name="T1">Álláskereséshez kapcsolódó szövegek</text:span></text:h><text:list text:style-name="L2"><text:list-item><text:p text:style-name="P8"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Önéletrajz (CV)</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P9">Cél: a pályázó bemutatása </text:p></text:list-item><text:list-item><text:p text:style-name="P9">Típusai: időrendi, funkcionális </text:p></text:list-item><text:list-item><text:p text:style-name="P9">Tartalma: személyes adatok, tanulmányok, tapasztalat, készségek </text:p></text:list-item><text:list-item><text:p text:style-name="P9">Jellemzői: tömörség, áttekinthetőség </text:p></text:list-item></text:list></text:list-item><text:list-item><text:p text:style-name="P8"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Motivációs levél</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P9">Cél: az alkalmasság és motiváció bemutatása </text:p></text:list-item><text:list-item><text:p text:style-name="P9">Személyesebb hangvétel, de formális </text:p></text:list-item><text:list-item><text:p text:style-name="P10">Felépítés: megszólítás, bemutatkozás, indoklás, zárás </text:p></text:list-item></text:list></text:list-item></text:list><text:h text:style-name="P7" text:outline-level="4">2.2. <text:span text:style-name="T1">Munkahelyi kommunikáció szövegtípusai</text:span></text:h><text:list text:style-name="L3"><text:list-item><text:p text:style-name="P11"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Hivatalos levél / e-mail</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P12">Cél: információközlés, kérés, kapcsolatfelvétel </text:p></text:list-item><text:list-item><text:p text:style-name="P12">Formai elemek: megszólítás, tárgy, szövegtörzs, elköszönés </text:p></text:list-item><text:list-item><text:p text:style-name="P12">Stílus: udvarias, tárgyilagos </text:p></text:list-item></text:list></text:list-item><text:list-item><text:p text:style-name="P11"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Jegyzőkönyv</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P12">Cél: megbeszélések, értekezletek rögzítése </text:p></text:list-item><text:list-item><text:p text:style-name="P12">Tartalma: időpont, helyszín, résztvevők, napirend, döntések </text:p></text:list-item><text:list-item><text:p text:style-name="P12">Tárgyilagos, tényszerű </text:p></text:list-item></text:list></text:list-item><text:list-item><text:p text:style-name="P11"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Beszámoló / jelentés</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P12">Cél: elvégzett munka bemutatása </text:p></text:list-item><text:list-item><text:p text:style-name="P12">Tartalma: célok, folyamat, eredmények, következtetések </text:p></text:list-item><text:list-item><text:p text:style-name="P13">Logikus szerkezet, szakmai nyelvezet </text:p></text:list-item></text:list></text:list-item></text:list><text:h text:style-name="P7" text:outline-level="4">2.3. <text:span text:style-name="T1">Hivatalos és jogi szövegek</text:span></text:h><text:list text:style-name="L4"><text:list-item><text:p text:style-name="P14"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Pályázat</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P15">Cél: támogatás vagy lehetőség elnyerése </text:p></text:list-item><text:list-item><text:p text:style-name="P15">Részei: célkitűzés, indoklás, költségvetés </text:p></text:list-item><text:list-item><text:p text:style-name="P15">Meggyőző, de formális stílus </text:p></text:list-item></text:list></text:list-item><text:list-item><text:p text:style-name="P14"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T3">Szerződés</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p><text:list><text:list-item><text:p text:style-name="P15">Cél: jogi megállapodás rögzítése </text:p></text:list-item><text:list-item><text:p text:style-name="P15">Pontos, egyértelmű megfogalmazás </text:p></text:list-item><text:list-item><text:p text:style-name="P16">Tartalmazza a felek adatait, feltételeket, kötelezettségeket </text:p></text:list-item></text:list></text:list-item></text:list><text:h text:style-name="P6" text:outline-level="3"><text:soft-page-break/>3. <text:span text:style-name="T1">A munkahelyi szövegek közös jellemzői</text:span></text:h><text:list text:style-name="L5"><text:list-item><text:p text:style-name="P17"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">Formális stílus</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P17"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">Pontosság és egyértelműség</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P17"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">Tömörség</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P17"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">Logikus felépítés</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P17"><text:span text:style-name="Strong_20_Emphasis"><text:span text:style-name="T2">Helyesírás és nyelvhelyesség fontossága</text:span></text:span><text:span text:style-name="T2"> </text:span></text:p></text:list-item><text:list-item><text:p text:style-name="P18">Gyakran sablonokhoz kötöttek</text:p></text:list-item></text:list><text:p text:style-name="P19"/></office:text></office:body></office:document-content>